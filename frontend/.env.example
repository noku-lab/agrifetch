# Leave empty for same-origin requests (Vite dev proxy or Caddy in production).
VITE_API_BASE_URL=

# Optional override; defaults to ws(s)://current-host (works with Vite /ws proxy).
# VITE_WS_BASE_URL=ws://localhost:5173

# Demo credentials (must match backend seed: python -m app.seed)
VITE_DEMO_EMAIL=demo@agrifetch.co.za
VITE_DEMO_PASSWORD=demo12345
