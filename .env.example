# Production deployment env for docker-compose.prod.yml.
# Copy to `.env` on the server and fill in. NEVER commit the real .env.

# --- TLS (domains are hardcoded in Caddyfile) ---
ACME_EMAIL=admin@agrifetch.com

# --- Container image (GHCR). Replace your-org with the GitHub owner. ---
FRONTEND_IMAGE=ghcr.io/your-org/agrifetch-frontend:latest

# --- Email / Resend ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=enquiries@agrifetch.com
ENQUIRY_TO_EMAIL=info@agrifetch.com
