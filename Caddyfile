# AgriFetch reverse proxy + automatic HTTPS.
# SITE_ADDRESS / ACME_EMAIL are injected from the environment (see compose).

{
	email {$ACME_EMAIL}
}

{$SITE_ADDRESS} {
	encode zstd gzip

	# All traffic -> Node server (serves SPA + handles /api/enquiry).
	reverse_proxy frontend:3000

	header {
		# Basic hardening.
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
	}
}
